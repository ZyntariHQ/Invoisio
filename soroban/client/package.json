{
  "name": "@invoisio/soroban-client",
  "version": "1.0.0",
  "description": "Soroban invoice-payment contract client helper library for Invoisio",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
