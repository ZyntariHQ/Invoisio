  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
